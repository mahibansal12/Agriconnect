# ── Server ──
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Database ──
MONGO_URI=mongodb://localhost:27017/agriconnect

# ── Auth ──
ACCESS_TOKEN_SECRET=change_this_access_secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=change_this_refresh_secret
REFRESH_TOKEN_EXPIRY=10d

# ── Cloudinary (avatars / crop images) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay (payments) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Email (Nodemailer / Gmail) ──
EMAIL_USER=
EMAIL_PASS=

# ── Twilio (SMS: OTP verification, order & payment alerts) ──
# Get these from https://console.twilio.com
# TWILIO_PHONE_NUMBER must be the Twilio number you purchased, in E.164
# format (e.g. +14155238886), and TWILIO_ACCOUNT_SID/AUTH_TOKEN come from
# the console dashboard.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Weather / Mandi / News / AI ──
OPENWEATHERMAP_API_KEY=
DATA_GOV_API_KEY=
DATA_GOV_RESOURCE_ID=
GNEWS_API_KEY=
GEMINI_API_KEY=
